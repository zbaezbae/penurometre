<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Le Pénuromètre</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Serif+Display:ital@0;1&display=swap');

  :root {
    --bg: #050810;
    --bg2: #080d1a;
    --cold: #4fc3f7;
    --cold-dim: #1a4a6b;
    --critical: #ff3d57;
    --tension: #ff9800;
    --watch: #ffd600;
    --ok: #00e5a0;
    --text: #c8d8e8;
    --text-dim: #4a6070;
    --panel: rgba(8, 16, 32, 0.85);
    --border: rgba(79, 195, 247, 0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    overflow: hidden;
    height: 100vh;
    width: 100vw;
    cursor: crosshair;
  }

  #canvas-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  canvas { display: block; }

  /* ─── HEADER ─── */
  #header {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    padding: 20px 28px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    pointer-events: none;
  }

  #logo h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    font-style: italic;
    letter-spacing: -0.5px;
    color: #fff;
    line-height: 1;
  }

  #logo h1 span {
    color: var(--cold);
  }

  #logo p {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-top: 4px;
  }

  #live-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--cold);
    text-transform: uppercase;
  }

  #live-dot {
    width: 6px; height: 6px;
    background: var(--cold);
    border-radius: 50%;
    animation: blink 1.4s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  /* ─── LEFT PANEL ─── */
  #panel-left {
    position: absolute;
    left: 20px;
    top: 80px;
    bottom: 20px;
    width: 240px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow-y: auto;
    scrollbar-width: none;
  }

  #panel-left::-webkit-scrollbar { display: none; }

  .panel-block {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 14px 16px;
    backdrop-filter: blur(12px);
  }

  .panel-label {
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
  }

  /* Filters */
  .filter-group { margin-bottom: 12px; }
  .filter-group:last-child { margin-bottom: 0; }
  .filter-title {
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .filter-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: none;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    padding: 4px 0;
    width: 100%;
    text-align: left;
    transition: color 0.2s;
  }

  .filter-btn:hover { color: #fff; }
  .filter-btn.active { color: #fff; }

  .filter-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .filter-count {
    margin-left: auto;
    font-size: 9px;
    color: var(--text-dim);
  }

  .filter-checkbox {
    width: 10px; height: 10px;
    border: 1px solid var(--text-dim);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 7px;
  }

  .filter-checkbox.checked {
    background: var(--cold);
    border-color: var(--cold);
    color: #000;
  }

  /* Stats */
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 4px 0;
    border-bottom: 1px solid rgba(79,195,247,0.06);
  }

  .stat-row:last-child { border-bottom: none; }

  .stat-label { font-size: 9px; color: var(--text-dim); }
  .stat-value { font-size: 14px; font-weight: 700; color: var(--cold); }
  .stat-value.critical { color: var(--critical); }

  /* ─── RIGHT PANEL ─── */
  #panel-right {
    position: absolute;
    right: 20px;
    top: 80px;
    width: 220px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Legend */
  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 3px 0;
    font-size: 10px;
  }

  .legend-icon {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ─── TOOLTIP ─── */
  #tooltip {
    position: absolute;
    z-index: 100;
    background: rgba(5, 12, 28, 0.96);
    border: 1px solid var(--cold-dim);
    padding: 14px 16px;
    pointer-events: none;
    display: none;
    max-width: 260px;
    backdrop-filter: blur(16px);
  }

  #tooltip.visible { display: block; }

  .tt-drug {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 15px;
    color: #fff;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .tt-section-label {
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
    margin-top: 6px;
  }
  .tt-iupac {
    font-size: 9px;
    color: rgba(79,195,247,0.6);
    line-height: 1.4;
    font-style: italic;
    margin-bottom: 3px;
    word-break: break-word;
  }
  .tt-formula {
    font-size: 11px;
    color: var(--cold);
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .tt-markets {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .tt-market-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-size: 10px;
  }
  .tt-market-flag {
    font-size: 13px;
    flex-shrink: 0;
    width: 18px;
  }
  .tt-market-name {
    color: var(--text-dim);
    font-size: 9px;
    flex-shrink: 0;
    width: 22px;
  }
  .tt-market-val {
    color: var(--text);
    font-size: 9.5px;
    line-height: 1.3;
  }
  .tt-divider {
    border-top: 1px solid var(--border);
    margin: 8px 0 6px;
  }
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    color: var(--text-dim);
    padding: 2px 0;
  }

  .tt-val { color: var(--text); }

  .tt-badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .badge-critique { background: rgba(255,61,87,0.15); color: var(--critical); border: 1px solid rgba(255,61,87,0.3); }
  .badge-tension { background: rgba(255,152,0,0.15); color: var(--tension); border: 1px solid rgba(255,152,0,0.3); }
  .badge-vigilance { background: rgba(255,214,0,0.15); color: var(--watch); border: 1px solid rgba(255,214,0,0.3); }

  /* ─── BOTTOM BAR ─── */
  #bottom-bar {
    position: absolute;
    bottom: 20px;
    left: 280px;
    right: 260px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    pointer-events: none;
  }

  #ticker {
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 1.5px;
    overflow: hidden;
    white-space: nowrap;
  }

  #ticker span {
    color: var(--cold);
  }

  /* ─── SCANLINES ─── */
  #scanlines {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
  }

  /* ─── VIGNETTE ─── */
  #vignette {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.7) 100%);
  }

  /* ─── GRID OVERLAY ─── */
  #grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.03;
    background-image:
      linear-gradient(rgba(79,195,247,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79,195,247,1) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Scroll hint */
  #hint {
    position: absolute;
    bottom: 22px;
    right: 240px;
    z-index: 10;
    font-size: 8px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-transform: uppercase;
    pointer-events: none;
    animation: fadeHint 4s ease 2s forwards;
    opacity: 1;
  }

  @keyframes fadeHint {
    to { opacity: 0; }
  }

</style>
</head>
