    </button>
    <button class="filter-btn" data-severity="vigilance" onclick="setSeverity('vigilance')">
      <div class="filter-dot" style="background:#ffd600"></div>
      Vigilance
      <span class="filter-count" id="count-vigilance">8</span>
    </button>
  </div>

  <div class="panel-block">
    <div class="panel-label">Filtrer par cause</div>
    <div id="cause-filters"></div>
  </div>

  <div class="panel-block">
    <div class="panel-label">Classe thérapeutique</div>
    <div id="class-filters"></div>
  </div>

</div>

<!-- RIGHT PANEL -->
<div id="panel-right">
  <div class="panel-block">
    <div class="panel-label">Légende</div>
    <div class="legend-item"><div class="legend-icon" style="background:#ff3d57; box-shadow:0 0 6px #ff3d57"></div> Critique — rupture avérée</div>
    <div class="legend-item"><div class="legend-icon" style="background:#ff9800; box-shadow:0 0 6px #ff9800"></div> Tension — stock bas</div>
    <div class="legend-item"><div class="legend-icon" style="background:#ffd600; box-shadow:0 0 6px #ffd600"></div> Vigilance — surveillance</div>
    <div style="margin-top:10px; border-top:1px solid var(--border); padding-top:10px;">
      <div class="legend-item">
        <div style="width:30px; height:1px; background: linear-gradient(90deg, #4fc3f7, transparent)"></div>
        Flux supply chain
      </div>
    </div>
  </div>

  <div class="panel-block" id="source-block">
    <div class="panel-label">Sources de données</div>
    <div style="font-size:9px; color:var(--text-dim); line-height:1.7">
      <div>→ openFDA Drug Shortages API</div>
      <div>→ ANSM (France)</div>
      <div>→ EMA (Europe)</div>
      <div>→ WHO Essential Medicines</div>
    </div>
  </div>
</div>

<!-- TOOLTIP -->
<div id="tooltip">
  <div class="tt-drug" id="tt-drug">—</div>
  <div id="tt-badge" class="tt-badge">—</div>

  <div class="tt-section-label">Identification chimique</div>
  <div class="tt-iupac" id="tt-iupac">—</div>
  <div class="tt-formula" id="tt-formula">—</div>

  <div class="tt-section-label" style="margin-top:8px">Appellations commerciales</div>
  <div class="tt-markets" id="tt-markets"></div>

  <div class="tt-divider"></div>
  <div class="tt-row"><span>Pays</span><span class="tt-val" id="tt-country">—</span></div>
  <div class="tt-row"><span>Cause</span><span class="tt-val" id="tt-cause">—</span></div>
  <div class="tt-row"><span>Classe</span><span class="tt-val" id="tt-class">—</span></div>
  <div class="tt-row"><span>Source</span><span class="tt-val" id="tt-source">—</span></div>
  <div class="tt-row"><span>Depuis</span><span class="tt-val" id="tt-since">—</span></div>
</div>

<!-- BOTTOM BAR -->
<div id="bottom-bar">
  <div id="ticker">
    Cliquer sur un point pour le détail &nbsp;·&nbsp;
    <span>Faire pivoter</span> le globe au clic &nbsp;·&nbsp;
    Scroll pour zoomer
  </div>
</div>

<div id="hint">↕ Scroll · ↔ Drag · Click</div>

