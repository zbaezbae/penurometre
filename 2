    markets: { fr: "Rifadine / Rifampicine Sandoz / Rimactan", us: "Rifadin / Rimactane / Rifampicin Sandoz", uk: "Rifadin / Rimactane / Rifampicin Sandoz", de: "Rifa / Rifampicin Hexal / Rimactan", be: "Rifadine / Rifampicine Sandoz / Rimactan", cn: "利福平 (Lì fú píng) / 甲哌利福霉素", in: "Rifampicin / R-Cin / Macox" }
  },
  {
    drug: "Gentamicine ophtalmique", country: "Argentine", lat: -34.6, lon: -58.4, severity: "vigilance",
    cause: "Problème douanier", class: "Ophtalmologie", source: "ANMAT", since: "2023-04",
    iupac: "Complexe d'aminoglycosides (C₁, C₁a, C₂) produit par Micromonospora purpurea",
    formula: "C₂₁H₄₃N₅O₇ (composant C₁ majoritaire)",
    markets: { fr: "Gentalline collyre / Gentamicine Théa / Garamycine", us: "Garamycin / Genoptic / Gentamicin Bausch & Lomb", uk: "Genticin / Garamycin / Gentamicin Bausch", de: "Refobacin / Gentamicin Hexal / Garamycin Augentropfen", be: "Gentalline / Garamycine / Gentamicine Théa", cn: "硫酸庆大霉素 (Liú suān qìng dà méisù) / 正泰霉素", in: "Gentamicin IP / Garamycin / Gentamicin Cipla" }
  },
];

// Supply chain routes (from → to)
const SUPPLY_ROUTES = [
  { from: [31.0, 121.4], to: [46.2, 2.3], label: "Chine → France (API Amoxicilline)" },
  { from: [31.0, 121.4], to: [52.5, 13.4], label: "Chine → Europe (Antibiotiques)" },
  { from: [23.0, 72.6], to: [38.9, -77.0], label: "Inde (Gujarat) → USA (Oncologie)" },
  { from: [28.6, 77.2], to: [50.8, 4.4], label: "Inde (Delhi) → Europe (Pénicilline)" },
  { from: [1.4, 103.8], to: [48.9, 2.3], label: "Singapour → France (Paracétamol)" },
  { from: [31.0, 121.4], to: [52.4, 4.9], label: "Chine → Pays-Bas (Doxycycline API)" },
];

// ═══════════════════════════════════════════
//  THREE.JS GLOBE
// ═══════════════════════════════════════════

const container = document.getElementById('canvas-container');
const W = window.innerWidth, H = window.innerHeight;

const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(W, H);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setClearColor(0x050810, 1);
container.appendChild(renderer.domElement);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(45, W/H, 0.1, 1000);
camera.position.z = 2.8;

// Lumières
const ambientLight = new THREE.AmbientLight(0x112244, 0.8);
scene.add(ambientLight);
const dirLight = new THREE.DirectionalLight(0x4fc3f7, 0.6);
dirLight.position.set(5, 3, 5);
scene.add(dirLight);
const rimLight = new THREE.DirectionalLight(0x001133, 1.0);
rimLight.position.set(-5, -3, -2);
scene.add(rimLight);

// Globe principal
const globeGeo = new THREE.SphereGeometry(1, 64, 64);
const globeMat = new THREE.MeshPhongMaterial({
  color: 0x0a1628,
  emissive: 0x020818,
  specular: 0x4fc3f7,
  shininess: 80,
  transparent: true,
  opacity: 0.95,
  wireframe: false,
});
const globe = new THREE.Mesh(globeGeo, globeMat);
scene.add(globe);

// Sphère wireframe (grille géographique)
const wireGeo = new THREE.SphereGeometry(1.001, 32, 32);
const wireMat = new THREE.MeshBasicMaterial({
  color: 0x1a3a5c,
  wireframe: true,
  transparent: true,
  opacity: 0.08,
});
const wireFrame = new THREE.Mesh(wireGeo, wireMat);
scene.add(wireFrame);

// Atmosphère
const atmGeo = new THREE.SphereGeometry(1.12, 64, 64);
const atmMat = new THREE.MeshPhongMaterial({
  color: 0x0d1f40,
  emissive: 0x0a1830,
  transparent: true,
  opacity: 0.18,
  side: THREE.BackSide,
});
const atmosphere = new THREE.Mesh(atmGeo, atmMat);
scene.add(atmosphere);

// Halo extérieur
const haloGeo = new THREE.SphereGeometry(1.2, 64, 64);
const haloMat = new THREE.MeshBasicMaterial({
  color: 0x4fc3f7,
  transparent: true,
  opacity: 0.04,
  side: THREE.BackSide,
});
scene.add(new THREE.Mesh(haloGeo, haloMat));

// Conversion lat/lon → position 3D
function latLonToVec3(lat, lon, r = 1) {
  const phi = (90 - lat) * Math.PI / 180;
  const theta = (lon + 180) * Math.PI / 180;
  return new THREE.Vector3(
    -r * Math.sin(phi) * Math.cos(theta),
     r * Math.cos(phi),
     r * Math.sin(phi) * Math.sin(theta)
  );
}

// Couleur par sévérité
const SEV_COLOR = {
  critique:  0xff3d57,
  tension:   0xff9800,
  vigilance: 0xffd600,
};
const SEV_HEX = {
  critique:  '#ff3d57',
  tension:   '#ff9800',
  vigilance: '#ffd600',
};

// Points de pénurie
const pointObjects = [];
const pointGroup = new THREE.Group();
scene.add(pointGroup);

SHORTAGES.forEach((s, i) => {
  const pos = latLonToVec3(s.lat, s.lon, 1.01);
  const color = SEV_COLOR[s.severity];

  // Sphère principale
  const geo = new THREE.SphereGeometry(0.012, 12, 12);
  const mat = new THREE.MeshBasicMaterial({ color });
  const dot = new THREE.Mesh(geo, mat);
  dot.position.copy(pos);
  dot.userData = { index: i, type: 'dot' };

  // Ring pulsant
  const ringGeo = new THREE.RingGeometry(0.018, 0.022, 24);
  const ringMat = new THREE.MeshBasicMaterial({
    color, transparent: true, opacity: 0.7, side: THREE.DoubleSide,
  });
  const ring = new THREE.Mesh(ringGeo, ringMat);
  ring.position.copy(pos);
  ring.lookAt(new THREE.Vector3(0,0,0));
  ring.userData = { phase: Math.random() * Math.PI * 2, type: 'ring', index: i };

  // Halo glow
  const glowGeo = new THREE.SphereGeometry(0.022, 12, 12);
  const glowMat = new THREE.MeshBasicMaterial({
    color, transparent: true, opacity: 0.2,
  });
  const glow = new THREE.Mesh(glowGeo, glowMat);
  glow.position.copy(pos);

  pointGroup.add(dot);
  pointGroup.add(ring);
  pointGroup.add(glow);
  pointObjects.push({ dot, ring, glow, data: s });
});

// Lignes de supply chain
const lineGroup = new THREE.Group();
scene.add(lineGroup);

function makeSupplyArc(fromLatLon, toLatLon) {
  const from = latLonToVec3(fromLatLon[0], fromLatLon[1], 1.01);
  const to = latLonToVec3(toLatLon[0], toLatLon[1], 1.01);
  const mid = from.clone().add(to).normalize().multiplyScalar(1.35);
  const curve = new THREE.QuadraticBezierCurve3(from, mid, to);
  const pts = curve.getPoints(60);
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const mat = new THREE.LineBasicMaterial({
    color: 0x4fc3f7,
    transparent: true,
    opacity: 0.2,
  });
  return new THREE.Line(geo, mat);
}

SUPPLY_ROUTES.forEach(r => {
  const line = makeSupplyArc(r.from, r.to);
  line.userData = { type: 'supply', label: r.label };
  lineGroup.add(line);
});

// Particules de fond (étoiles)
const starGeo = new THREE.BufferGeometry();
const starPos = [];
for (let i = 0; i < 2000; i++) {
  starPos.push((Math.random()-0.5)*80, (Math.random()-0.5)*80, (Math.random()-0.5)*80);
}
starGeo.setAttribute('position', new THREE.Float32BufferAttribute(starPos, 3));
const starMat = new THREE.PointsMaterial({ color: 0x4a6a8a, size: 0.05, transparent: true, opacity: 0.6 });
scene.add(new THREE.Points(starGeo, starMat));

// ═══════════════════════════════════════════
//  INTERACTION — rotation, raycasting
// ═══════════════════════════════════════════

let isDragging = false;
let prevMouse = { x: 0, y: 0 };
let rotVel = { x: 0, y: 0 };
let targetRot = { x: 0.3, y: 0 };
let currentRot = { x: 0.3, y: 0 };
const globeGroup = new THREE.Group();
scene.add(globeGroup);
globeGroup.add(globe);
globeGroup.add(wireFrame);
globeGroup.add(pointGroup);
globeGroup.add(lineGroup);

const raycaster = new THREE.Raycaster();
const mouse = new THREE.Vector2();

renderer.domElement.addEventListener('mousedown', e => {
  isDragging = true;
  prevMouse = { x: e.clientX, y: e.clientY };
  rotVel = { x: 0, y: 0 };
});

renderer.domElement.addEventListener('mousemove', e => {
  // Tooltip raycasting
  mouse.x = (e.clientX / W) * 2 - 1;
  mouse.y = -(e.clientY / H) * 2 + 1;
  handleHover(e.clientX, e.clientY);

  if (!isDragging) return;
  const dx = e.clientX - prevMouse.x;
  const dy = e.clientY - prevMouse.y;
  rotVel.y = dx * 0.005;
  rotVel.x = dy * 0.005;
  targetRot.y += rotVel.y;
  targetRot.x += rotVel.x;
  targetRot.x = Math.max(-1.2, Math.min(1.2, targetRot.x));
  prevMouse = { x: e.clientX, y: e.clientY };
});

renderer.domElement.addEventListener('mouseup', () => { isDragging = false; });
renderer.domElement.addEventListener('mouseleave', () => { isDragging = false; });

renderer.domElement.addEventListener('wheel', e => {
  camera.position.z = Math.max(1.5, Math.min(5, camera.position.z + e.deltaY * 0.003));
});

// Touch
renderer.domElement.addEventListener('touchstart', e => {
  isDragging = true;
  prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
});
renderer.domElement.addEventListener('touchmove', e => {
  if (!isDragging) return;
  const dx = e.touches[0].clientX - prevMouse.x;
  const dy = e.touches[0].clientY - prevMouse.y;
  targetRot.y += dx * 0.005;
  targetRot.x += dy * 0.005;
  prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
  e.preventDefault();
}, { passive: false });
renderer.domElement.addEventListener('touchend', () => { isDragging = false; });

// Hover / tooltip
let hoveredIndex = -1;

function handleHover(cx, cy) {
  raycaster.setFromCamera(mouse, camera);
  const targets = pointObjects.map(p => p.dot);
  const hits = raycaster.intersectObjects(targets);

  const tooltip = document.getElementById('tooltip');

  if (hits.length > 0) {
    const idx = hits[0].object.userData.index;
    if (idx !== hoveredIndex) {
      hoveredIndex = idx;
      const s = SHORTAGES[idx];
      document.getElementById('tt-drug').textContent = s.drug;
      const badge = document.getElementById('tt-badge');
      badge.textContent = s.severity.toUpperCase();
      badge.className = 'tt-badge badge-' + s.severity;

      // Identité chimique
      document.getElementById('tt-iupac').textContent = s.iupac || '—';
      document.getElementById('tt-formula').textContent = s.formula || '—';

      // Marchés commerciaux dans l'ordre de priorité
      const MARKET_ORDER = [
        { key: 'fr', flag: '🇫🇷', label: 'FR' },
        { key: 'us', flag: '🇺🇸', label: 'US' },
        { key: 'uk', flag: '🇬🇧', label: 'UK' },
        { key: 'de', flag: '🇩🇪', label: 'DE' },
        { key: 'be', flag: '🇧🇪', label: 'BE' },
        { key: 'cn', flag: '🇨🇳', label: 'CN' },
        { key: 'in', flag: '🇮🇳', label: 'IN' },
      ];
      const marketsDiv = document.getElementById('tt-markets');
      marketsDiv.innerHTML = '';
      if (s.markets) {
        MARKET_ORDER.forEach(m => {
          if (s.markets[m.key]) {
            const row = document.createElement('div');
            row.className = 'tt-market-row';
            row.innerHTML = `<span class="tt-market-flag">${m.flag}</span><span class="tt-market-name">${m.label}</span><span class="tt-market-val">${s.markets[m.key]}</span>`;
            marketsDiv.appendChild(row);
          }
        });
      }

      document.getElementById('tt-country').textContent = s.country;
      document.getElementById('tt-cause').textContent = s.cause;
      document.getElementById('tt-class').textContent = s.class;
      document.getElementById('tt-source').textContent = s.source;
      document.getElementById('tt-since').textContent = s.since;
    }
    tooltip.classList.add('visible');
    tooltip.style.left = (cx + 16) + 'px';
    tooltip.style.top  = (cy - 20) + 'px';
    // Adjust if off-screen
    if (cx + 280 > W) tooltip.style.left = (cx - 270) + 'px';
    if (cy + 160 > H) tooltip.style.top  = (cy - 150) + 'px';
  } else {
    hoveredIndex = -1;
    tooltip.classList.remove('visible');
  }
}

// ═══════════════════════════════════════════
//  FILTRES
// ═══════════════════════════════════════════

let activeSeverity = 'all';
let activeCauses = new Set();
let activeClasses = new Set();

const causes = [...new Set(SHORTAGES.map(s => s.cause))];
const classes = [...new Set(SHORTAGES.map(s => s.class))];

function buildFilters() {
  const causeDiv = document.getElementById('cause-filters');
  const classDiv = document.getElementById('class-filters');

  causes.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'filter-btn';
    btn.innerHTML = `<div class="filter-checkbox" id="cause-${c.replace(/\s/g,'_')}"></div>${c.length > 22 ? c.slice(0,22)+'…' : c}`;
    btn.onclick = () => toggleCause(c, btn);
    causeDiv.appendChild(btn);
  });

  classes.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'filter-btn';
    btn.innerHTML = `<div class="filter-checkbox" id="class-${c.replace(/\s/g,'_')}"></div>${c}`;
    btn.onclick = () => toggleClass(c, btn);
    classDiv.appendChild(btn);
  });
}

function toggleCause(cause, btn) {
  if (activeCauses.has(cause)) { activeCauses.delete(cause); }
  else activeCauses.add(cause);
  updateFilters();
}

function toggleClass(cls, btn) {
  if (activeClasses.has(cls)) { activeClasses.delete(cls); }
  else activeClasses.add(cls);
  updateFilters();
}

window.setSeverity = function(sev) {
  activeSeverity = sev;
  updateFilters();
};

function updateFilters() {
  pointObjects.forEach(({ dot, ring, glow, data }, i) => {
    let visible = true;
    if (activeSeverity !== 'all' && data.severity !== activeSeverity) visible = false;
    if (activeCauses.size > 0 && !activeCauses.has(data.cause)) visible = false;
    if (activeClasses.size > 0 && !activeClasses.has(data.class)) visible = false;
    dot.visible = ring.visible = glow.visible = visible;
  });

  // Update supply lines
  lineGroup.children.forEach(line => {
    line.visible = activeSeverity === 'all';
  });
}

buildFilters();

// ═══════════════════════════════════════════
//  BOUCLE D'ANIMATION
// ═══════════════════════════════════════════

const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Rotation auto douce
  if (!isDragging) {
    rotVel.y *= 0.96;
    targetRot.y += 0.0015 + rotVel.y;
  }

  currentRot.x += (targetRot.x - currentRot.x) * 0.08;
  currentRot.y += (targetRot.y - currentRot.y) * 0.08;
  globeGroup.rotation.x = currentRot.x;
  globeGroup.rotation.y = currentRot.y;

  // Pulsation des rings
  pointObjects.forEach(({ ring, dot, glow }) => {
    if (!ring.visible) return;
    const phase = ring.userData.phase || 0;
    const pulse = (Math.sin(t * 2.5 + phase) + 1) / 2;
    ring.material.opacity = 0.2 + pulse * 0.6;
    const s = 1 + pulse * 0.5;
    ring.scale.set(s, s, 1);
    glow.material.opacity = 0.05 + pulse * 0.18;
  });

  // Pulsation lignes supply
  lineGroup.children.forEach((line, i) => {
    const p = (Math.sin(t * 0.8 + i * 1.2) + 1) / 2;
    line.material.opacity = 0.08 + p * 0.22;
  });

  renderer.render(scene, camera);
}

animate();

// Resize
window.addEventListener('resize', () => {
  const W = window.innerWidth, H = window.innerHeight;
  camera.aspect = W/H;
  camera.updateProjectionMatrix();
  renderer.setSize(W, H);
});

// Ticker update
const tickerMsgs = [
  "→ <span>35 pénuries</span> documentées sur 18 pays &nbsp;·&nbsp; Sources : openFDA · ANSM · EMA · WHO",
  "→ <span>Amoxicilline</span> : rupture de stock sur 3 marchés européens depuis nov. 2022",
  "→ <span>Oncologie</span> : fermeture d'usine Intas (Inde) provoque pénurie mondiale de cisplatine",
  "→ <span>Antibiotiques</span> : 70% des principes actifs mondiaux produits en Chine et en Inde",
];
let tickIdx = 0;
setInterval(() => {
  tickIdx = (tickIdx + 1) % tickerMsgs.length;
  document.getElementById('ticker').innerHTML = tickerMsgs[tickIdx];
}, 5000);

</script>
